    {
      "mode": "data",
      "type": "template_file",
      "name": "user_data",
      "provider": "provider[\"registry.terraform.io/hashicorp/template\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "filename": null,
            "id": "ddd67df4c3680552f452490f8425c63f43e1663e05e1d3fd72c831fdd04d3697",
            "rendered": "#!/bin/bash\n# Actualizar paquetes\napt-get update\napt-get upgrade -y\n    \n# Instalar dependencias\napt-get install -y git amazon-efs-utils nfs-common docker.io docker-compose\n\n# Habilitar y arrancar Docker\nsystemctl enable docker\nsystemctl start docker\n    \n# Crear directorio y montar EFS\nmkdir -p /mnt/efs\nmount -t nfs4 -o nfsvers=4.1,rsize=1048576,wsize=1048576,hard,timeo=600,retrans=2,noresvport fs-030d8e4cbfe2baedc.efs.us-east-1.amazonaws.com:/ /mnt/efs\n    \n# Asegurar que EFS se monte después de reinicios\necho \"fs-030d8e4cbfe2baedc.efs.us-east-1.amazonaws.com:/ /mnt/efs nfs4 nfsvers=4.1,rsize=1048576,wsize=1048576,hard,timeo=600,retrans=2,noresvport 0 0\" \u003e\u003e /etc/fstab\n    \n# Clonar repositorio\ngit clone https://github.com/Alkran93/bookstore-monolith.git /home/ubuntu/bookstore-monolith\nchown -R ubuntu:ubuntu /home/ubuntu/bookstore-monolith\n    \n# Crear directorio para almacenar imágenes y otros archivos compartidos\nmkdir -p /mnt/efs/uploads\nchmod 777 /mnt/efs/uploads\n    \n# Configurar variables de entorno para la aplicación\ncat \u003e /home/ubuntu/bookstore-monolith/.env \u003c\u003cEOL\nMYSQL_ROOT_PASSWORD=123456789*\nMYSQL_DATABASE=bookstore\nMYSQL_USER=admin\nMYSQL_PASSWORD=123456789*\nMYSQL_HOST=bookstore-db.cpcxnlpdyvng.us-east-1.rds.amazonaws.com\nMYSQL_PORT=3306\nUPLOADS_FOLDER=/mnt/efs/uploads\nEOL\n    \n# Modificar docker-compose.yml para usar RDS en lugar de MySQL local\ncd /home/ubuntu/bookstore-monolith\nsed -i 's/- db/#- db/g' docker-compose.yml  # Comentar la dependencia de db\nsed -i '/db:/,/volumes:/d' docker-compose.yml  # Eliminar sección de servicio db\n    \n# Iniciar la aplicación\ndocker-compose up -d\n",
            "template": "#!/bin/bash\n# Actualizar paquetes\napt-get update\napt-get upgrade -y\n    \n# Instalar dependencias\napt-get install -y git amazon-efs-utils nfs-common docker.io docker-compose\n\n# Habilitar y arrancar Docker\nsystemctl enable docker\nsystemctl start docker\n    \n# Crear directorio y montar EFS\nmkdir -p /mnt/efs\nmount -t nfs4 -o nfsvers=4.1,rsize=1048576,wsize=1048576,hard,timeo=600,retrans=2,noresvport fs-030d8e4cbfe2baedc.efs.us-east-1.amazonaws.com:/ /mnt/efs\n    \n# Asegurar que EFS se monte después de reinicios\necho \"fs-030d8e4cbfe2baedc.efs.us-east-1.amazonaws.com:/ /mnt/efs nfs4 nfsvers=4.1,rsize=1048576,wsize=1048576,hard,timeo=600,retrans=2,noresvport 0 0\" \u003e\u003e /etc/fstab\n    \n# Clonar repositorio\ngit clone https://github.com/Alkran93/bookstore-monolith.git /home/ubuntu/bookstore-monolith\nchown -R ubuntu:ubuntu /home/ubuntu/bookstore-monolith\n    \n# Crear directorio para almacenar imágenes y otros archivos compartidos\nmkdir -p /mnt/efs/uploads\nchmod 777 /mnt/efs/uploads\n    \n# Configurar variables de entorno para la aplicación\ncat \u003e /home/ubuntu/bookstore-monolith/.env \u003c\u003cEOL\nMYSQL_ROOT_PASSWORD=123456789*\nMYSQL_DATABASE=bookstore\nMYSQL_USER=admin\nMYSQL_PASSWORD=123456789*\nMYSQL_HOST=bookstore-db.cpcxnlpdyvng.us-east-1.rds.amazonaws.com\nMYSQL_PORT=3306\nUPLOADS_FOLDER=/mnt/efs/uploads\nEOL\n    \n# Modificar docker-compose.yml para usar RDS en lugar de MySQL local\ncd /home/ubuntu/bookstore-monolith\nsed -i 's/- db/#- db/g' docker-compose.yml  # Comentar la dependencia de db\nsed -i '/db:/,/volumes:/d' docker-compose.yml  # Eliminar sección de servicio db\n    \n# Iniciar la aplicación\ndocker-compose up -d\n",
            "vars": null
          },
          "sensitive_attributes": [
            [
              {
                "type": "get_attr",
                "value": "template"
              }
            ]
          ]
        }
      ]
